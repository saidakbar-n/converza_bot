# Converza bot — copy to .env and fill in values

ENV=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Hermes Agent (start gateway: hermes gateway)
HERMES_URL=http://127.0.0.1:8642
HERMES_API_KEY=change-me-local-dev
HERMES_MODEL=hermes-agent
API_SERVER_ENABLED=true
API_SERVER_KEY=change-me-local-dev
ANTHROPIC_API_KEY=your_anthropic_api_key_here

TELEGRAM_BOT_TOKEN=your_sales_bot_token_here
TELEGRAM_BOT_USERNAME=ConverzaSales_bot
TELEGRAM_APP_BOT_TOKEN=your_app_bot_token_here
TELEGRAM_APP_BOT_USERNAME=ConverzaApp_bot
TELEGRAM_WEBHOOK_SECRET=

# Converza subscription (Click on @ConverzaApp_bot)
CONVERZA_SUBSCRIPTION_PROVIDER_TOKEN=
CONVERZA_SUBSCRIPTION_PRICE_UZS=500000
SUBSCRIPTION_REQUIRED=false

WEB_APP_URL=http://localhost:8001

HITL_ENABLED=false

ADMIN_TELEGRAM_IDS=your_telegram_user_id

DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000001

USD_TO_UZS=12500
DEFAULT_INVOICE_AMOUNT_UZS=375000
